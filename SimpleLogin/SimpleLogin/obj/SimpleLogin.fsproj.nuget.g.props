<?xml version="1.0" encoding="utf-8" standalone="no"?>
<Project ToolsVersion="14.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <RestoreSuccess Condition=" '$(RestoreSuccess)' == '' ">True</RestoreSuccess>
    <RestoreTool Condition=" '$(RestoreTool)' == '' ">NuGet</RestoreTool>
    <ProjectAssetsFile Condition=" '$(ProjectAssetsFile)' == '' ">$(MSBuildThisFileDirectory)project.assets.json</ProjectAssetsFile>
    <NuGetPackageRoot Condition=" '$(NuGetPackageRoot)' == '' ">$(UserProfile)\.nuget\packages\</NuGetPackageRoot>
    <NuGetPackageFolders Condition=" '$(NuGetPackageFolders)' == '' ">C:\Users\A\.nuget\packages\;C:\Program Files (x86)\Microsoft Visual Studio\Shared\NuGetPackages</NuGetPackageFolders>
    <NuGetProjectStyle Condition=" '$(NuGetProjectStyle)' == '' ">PackageReference</NuGetProjectStyle>
    <NuGetToolVersion Condition=" '$(NuGetToolVersion)' == '' ">7.0.0</NuGetToolVersion>
  </PropertyGroup>
  <ItemGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <SourceRoot Include="C:\Users\A\.nuget\packages\" />
    <SourceRoot Include="C:\Program Files (x86)\Microsoft Visual Studio\Shared\NuGetPackages\" />
  </ItemGroup>
  <ImportGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <Import Project="$(NuGetPackageRoot)microsoft.codeanalysis.analyzers\3.11.0\buildTransitive\Microsoft.CodeAnalysis.Analyzers.props" Condition="Exists('$(NuGetPackageRoot)microsoft.codeanalysis.analyzers\3.11.0\buildTransitive\Microsoft.CodeAnalysis.Analyzers.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.entityframeworkcore\10.0.3\buildTransitive\net10.0\Microsoft.EntityFrameworkCore.props" Condition="Exists('$(NuGetPackageRoot)microsoft.entityframeworkcore\10.0.3\buildTransitive\net10.0\Microsoft.EntityFrameworkCore.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.entityframeworkcore.design\10.0.3\build\net10.0\Microsoft.EntityFrameworkCore.Design.props" Condition="Exists('$(NuGetPackageRoot)microsoft.entityframeworkcore.design\10.0.3\build\net10.0\Microsoft.EntityFrameworkCore.Design.props')" />
  </ImportGroup>
  <PropertyGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <PkgNuGet_Common Condition=" '$(PkgNuGet_Common)' == '' ">C:\Users\A\.nuget\packages\nuget.common\7.3.0</PkgNuGet_Common>
    <PkgNuGet_Packaging Condition=" '$(PkgNuGet_Packaging)' == '' ">C:\Users\A\.nuget\packages\nuget.packaging\7.3.0</PkgNuGet_Packaging>
    <PkgNuGet_Protocol Condition=" '$(PkgNuGet_Protocol)' == '' ">C:\Users\A\.nuget\packages\nuget.protocol\7.3.0</PkgNuGet_Protocol>
    <PkgMicrosoft_CodeAnalysis_Analyzers Condition=" '$(PkgMicrosoft_CodeAnalysis_Analyzers)' == '' ">C:\Users\A\.nuget\packages\microsoft.codeanalysis.analyzers\3.11.0</PkgMicrosoft_CodeAnalysis_Analyzers>
    <PkgMicrosoft_EntityFrameworkCore_Design Condition=" '$(PkgMicrosoft_EntityFrameworkCore_Design)' == '' ">C:\Users\A\.nuget\packages\microsoft.entityframeworkcore.design\10.0.3</PkgMicrosoft_EntityFrameworkCore_Design>
    <PkgMicrosoft_VisualStudio_Web_CodeGeneration_Design Condition=" '$(PkgMicrosoft_VisualStudio_Web_CodeGeneration_Design)' == '' ">C:\Users\A\.nuget\packages\microsoft.visualstudio.web.codegeneration.design\10.0.2</PkgMicrosoft_VisualStudio_Web_CodeGeneration_Design>
    <PkgMicrosoft_EntityFrameworkCore_Tools Condition=" '$(PkgMicrosoft_EntityFrameworkCore_Tools)' == '' ">C:\Users\A\.nuget\packages\microsoft.entityframeworkcore.tools\10.0.3</PkgMicrosoft_EntityFrameworkCore_Tools>
    <PkgMicrosoft_EntityFrameworkCore_SqlServer Condition=" '$(PkgMicrosoft_EntityFrameworkCore_SqlServer)' == '' ">C:\Users\A\.nuget\packages\microsoft.entityframeworkcore.sqlserver\10.0.3</PkgMicrosoft_EntityFrameworkCore_SqlServer>
    <PkgMicrosoft_Build_Tasks_Core Condition=" '$(PkgMicrosoft_Build_Tasks_Core)' == '' ">C:\Users\A\.nuget\packages\microsoft.build.tasks.core\18.3.3</PkgMicrosoft_Build_Tasks_Core>
    <PkgMicrosoft_AspNetCore_Mvc_Razor_RuntimeCompilation Condition=" '$(PkgMicrosoft_AspNetCore_Mvc_Razor_RuntimeCompilation)' == '' ">C:\Users\A\.nuget\packages\microsoft.aspnetcore.mvc.razor.runtimecompilation\10.0.3</PkgMicrosoft_AspNetCore_Mvc_Razor_RuntimeCompilation>
    <PkgMessagePack Condition=" '$(PkgMessagePack)' == '' ">C:\Users\A\.nuget\packages\messagepack\2.5.187</PkgMessagePack>
    <PkgFSharp_Core Condition=" '$(PkgFSharp_Core)' == '' ">C:\Users\A\.nuget\packages\fsharp.core\10.0.103</PkgFSharp_Core>
  </PropertyGroup>
</Project>